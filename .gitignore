# --- Python & Execution ---
# Byte-compiled / optimized / DLL files (temporary execution files)
__pycache__/
*.py[cod]
*$py.class

# --- Virtual Environments ---
# Distribution / packaging (never upload the venv folder)
venv/
.venv/
env/

# --- PyInstaller / Distribution ---
# Files generated when creating an executable (.exe)
build/
dist/
*.spec

# --- Data & Output Files ---
# Project-specific output files (keeps the repo clean of test results)
formatted_output.docx
saida_formatada.docx

# --- Editor & IDE Configs ---
# VS Code and JetBrains IDE settings
.vscode/
.idea/

# --- Operating System ---
# System-specific files (Windows/macOS metadata)
Thumbs.db
.DS_Store